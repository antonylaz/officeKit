# Database
DATABASE_URL="postgresql://officekit:officekit@localhost:5432/officekit?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend (transactional email)
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="OfficeKit <hello@officekit.se>"

# Upstash Redis (rate limiting, optional in dev — falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (optional - leave empty to disable error tracking)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Sentry — set all three to enable upload of source maps; otherwise runtime-only via sentry.*.config.ts
SENTRY_ORG=""
SENTRY_PROJECT=""

# Stripe (optional — stub mode when unset/false)
STRIPE_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Analytics (PostHog) — optional
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"

# Anthropic (AI office builder, Phase 10) — leave unset to disable the /ai-build feature
ANTHROPIC_API_KEY=""
AI_BUILD_MODEL="claude-opus-4-7"      # override to claude-sonnet-4-6 for ~5x lower cost
AI_BUILD_LIVE=""                      # set to "1" to enable the live smoke test (not in CI)

# BankID via Criipto (Phase 18) — leave unset to hide the BankID button on /sign-in
# Get these from https://dashboard.criipto.com — create an application with response type "code"
# and redirect URI {AUTH_URL}/api/auth/callback/bankid-se
CRIIPTO_ISSUER=""                     # e.g. https://your-tenant.criipto.id
CRIIPTO_CLIENT_ID=""
CRIIPTO_CLIENT_SECRET=""

# Tradera Public API (Phase 22) — live second-hand counts in the variant drawer
# Register at https://www.tradera.com/info/developer-info to receive an AppId.
# When unset, the "live on Tradera" chip is simply hidden.
TRADERA_APP_ID=""
TRADERA_APP_KEY=""                    # optional second header for higher rate limits

# Tradedoubler / Awin affiliate feed (Phase 22) — sync new-condition variants from retailer feeds.
# Run: AFFILIATE_FEED_URL=... AFFILIATE_FEED_SOURCE=tradedoubler_dustin pnpm tsx scripts/sync-affiliate-feeds.ts
# Leave blank for dev — the script will use prisma/mock-feeds/tradedoubler-dustin-sample.xml.
AFFILIATE_FEED_URL=""
AFFILIATE_FEED_SOURCE=""

# Price-update engine (Phase 22+) — daily cron at 03:00 Europe/Stockholm hits
# /api/v1/cron/sync-feeds. Configure all your retailer feeds in AFFILIATE_FEEDS as
# a JSON array; each entry maps to a RetailerId in src/lib/retailers.ts.
#   AFFILIATE_FEEDS='[{"feedSource":"tradedoubler_dustin","retailerId":"dustin","url":"https://..."},
#                     {"feedSource":"awin_komplett","retailerId":"komplett","url":"https://..."}]'
AFFILIATE_FEEDS=""
# Vercel injects this automatically when a cron job calls a route. Set it
# yourself only if you want to invoke the cron route manually from curl.
CRON_SECRET=""
